<Project>

  <PropertyGroup>
    <Version>0.1.0</Version>
    <Authors>Equibles</Authors>
    <Company>Equibles</Company>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageProjectUrl>https://github.com/EquiblesOpenSource/Equibles.AgentQL</PackageProjectUrl>
    <RepositoryUrl>https://github.com/EquiblesOpenSource/Equibles.AgentQL</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <PackageTags>efcore llm ai sql schema agent</PackageTags>
    <IsPackable>true</IsPackable>
  </PropertyGroup>

  <ItemGroup>
    <None Include="$(MSBuildThisFileDirectory)README.md" Pack="true" PackagePath="\" />
  </ItemGroup>

</Project>
